# =============================================================
# GalvanR.A.G — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# =============================================================

# ── LLM ──────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=            # optional fallback

# ── Vector Stores ─────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
CHROMA_PERSIST_DIR=./chroma_db

# ── Database ──────────────────────────────────────────────────
# Local development (without Docker):
#   DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/galvanrag
# Docker Compose (set automatically by docker-compose.yml):
#   DATABASE_URL=postgresql+asyncpg://galvan:galvanpass@db:5432/galvanrag
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/galvanrag

# ── PostgreSQL (Docker Compose only) ──────────────────────────
POSTGRES_USER=galvan
POSTGRES_PASSWORD=galvanpass
POSTGRES_DB=galvanrag

# ── Auth ──────────────────────────────────────────────────────
# Generate a secure key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_64_char_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO
