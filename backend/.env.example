# =============================================================
# GalvanR.A.G — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# =============================================================

# ── LLM ──────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=            # optional fallback

# ── Vector Stores ─────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
CHROMA_PERSIST_DIR=./chroma_db

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────
# The production Vercel origin (galvanrag.vercel.app) is always
# allowed in code.  Use this to add extra origins at deploy time,
# e.g. Vercel preview URLs.  Comma-separated.
CORS_ORIGINS=
