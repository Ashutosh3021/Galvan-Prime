# =============================================================
# GalvanR.A.G — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# =============================================================

# LLM
GEMINI_API_KEY=
OPENAI_API_KEY=            # optional fallback

# Vector Stores
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
CHROMA_PERSIST_DIR=./chroma_db

# Database (Supabase or any PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/galvanrag

# Auth
SECRET_KEY=change_me_to_a_32_byte_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development    # development | production
LOG_LEVEL=INFO
